# Application
APP_NAME=English Assessment Platform
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-long-random-secret-key
API_V1_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/english_assessment

# JWT
JWT_SECRET_KEY=change-me-jwt-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# AI — Groq (OpenAI-compatible) or OpenAI
OPENAI_API_KEY=gsk-your-groq-api-key
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=llama-3.3-70b-versatile

# Alternative env names
# AI_GATEWAY_API_KEY=
# AI_GATEWAY_BASE_URL=https://api.groq.com/openai/v1
# AI_MODEL=llama-3.3-70b-versatile

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080

# Assessment
EVALUATION_TURN_THRESHOLD=10
