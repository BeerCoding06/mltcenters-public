# ครูสอนภาษาอังกฤษ AI — ตัวอย่างการตั้งค่า
# Copy to backend/.env and adjust values

APP_NAME=ครูสอนภาษาอังกฤษ AI
DEBUG=false
SECRET_KEY=change-me-secret
JWT_SECRET_KEY=change-me-jwt
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/ai_tutor

# LLM: ollama | openai (Groq-compatible via OPENAI_BASE_URL)
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# Speech (open-source)
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
EDGE_TTS_VOICE=th-TH-PremwadeeNeural

# Avatar
AVATAR_ENGINE=viseme
MUSETALK_ENABLED=false
MUSETALK_URL=http://musetalk:7860
CORS_ORIGINS=http://localhost:5180,http://localhost:5173

EVALUATION_TURN_THRESHOLD=10
