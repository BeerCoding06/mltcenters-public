# App
APP_NAME=ครูสอนภาษาอังกฤษ AI
DEBUG=false
API_V1_PREFIX=/api/v1
SECRET_KEY=change-me-secret
JWT_SECRET_KEY=change-me-jwt
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/ai_tutor

# LLM — pick one provider
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# Speech (open-source / free)
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
EDGE_TTS_VOICE=th-TH-PremwadeeNeural

# Avatar
AVATAR_PORTRAIT_PATH=/app/assets/tutor-portrait.jpg
AVATAR_ENGINE=viseme
MUSETALK_URL=
MUSETALK_ENABLED=false
AUDIO_CACHE_DIR=/app/data/audio
VIDEO_CACHE_DIR=/app/data/video

# CORS
CORS_ORIGINS=http://localhost:5180,http://localhost:5173

EVALUATION_TURN_THRESHOLD=10
