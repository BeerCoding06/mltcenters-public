# App
APP_NAME=English Runner Game API
DEBUG=false
API_V1_PREFIX=/api/v1

# LLM — ollama | openai
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

CORS_ORIGINS=http://localhost:5190,http://localhost:5173

# Game tuning
INITIAL_HP=100
INITIAL_SPEED=200
MAX_SPEED=500
MIN_SPEED=80
CORRECT_SPEED_BOOST=40
WRONG_SPEED_PENALTY=50
CORRECT_SCORE=100
STREAK_BONUS=25
