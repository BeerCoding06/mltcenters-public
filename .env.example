# AI — Groq (OpenAI-compatible) or OpenAI
# Use either OPENAI_* or AI_GATEWAY_* (both work; OPENAI_* takes precedence for key/base if set)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=llama-3.3-70b-versatile

# Alternative names (same values as above)
# AI_GATEWAY_API_KEY=
# AI_GATEWAY_BASE_URL=https://api.groq.com/openai/v1
# AI_MODEL=llama-3.3-70b-versatile

PORT=3000
DEBUG=false

# Registration email → mltcenterth@gmail.com
REGISTER_TO_EMAIL=mltcenterth@gmail.com
SMTP_USER=mltcenterth@gmail.com
SMTP_PASS=

# Optional: Resend (if you switch email provider later)
# RESEND_API_KEY=
# EMAIL_FROM=MLTCENTERS <onboarding@resend.dev>
