# AI — Groq (OpenAI-compatible) or OpenAI
# Use either OPENAI_* or AI_GATEWAY_* (both work; OPENAI_* takes precedence for key/base if set)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=llama-3.3-70b-versatile

# Alternative names (same values as above)
# AI_GATEWAY_API_KEY=
# AI_GATEWAY_BASE_URL=https://api.groq.com/openai/v1
# AI_MODEL=llama-3.3-70b-versatile

PORT=3000
DEBUG=false
# Set ASSESS_DEBUG=1 to log final transcript, prompt, history, and response for /api/assess
# ASSESS_DEBUG=1

# Analytics (first-party)
ANALYTICS_ENABLED=true
ANALYTICS_ADMIN_TOKEN=
ANALYTICS_IP_SALT=
# Optional Postgres — leave empty to use file store at server/data/analytics.json
DATABASE_URL=
# ANALYTICS_FILE_PATH=

# Registration email (PHPMailer — recommended)
USE_PHP_MAILER=true
# Comma-separated recipients for registration notifications
REGISTER_TO_EMAIL=paradon.pokpingmaung@gmail.com,mltcenterth@gmail.com
MAIL_SMTP_USER=paradon.pokpingmaung@gmail.com
# Gmail App Password (16 chars) — NOT your normal Gmail password
# Create at: Google Account → Security → 2-Step Verification → App passwords
MAIL_SMTP_PASS=
MAIL_SMTP_FROM=paradon.pokpingmaung@gmail.com
MAIL_SMTP_FROM_NAME=MLTCENTERS Workshop
# Gmail SMTP (defaults shown)
# MAIL_SMTP_HOST=smtp.gmail.com
# MAIL_SMTP_PORT=587
# MAMP PHP path if needed: PHP_BIN=/Applications/MAMP/bin/php/php8.2.0/bin/php

# Option A: Resend (alternative — set USE_PHP_MAILER=false)
RESEND_API_KEY=
EMAIL_FROM=MLTCENTERS <onboarding@resend.dev>

# Option B: Node nodemailer fallback (alternative — set USE_PHP_MAILER=false)
SMTP_USER=
SMTP_PASS=
